<!DOCTYPE html>
<html lang="ru">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Мой Список Дел</title>
  <link rel="stylesheet" href="/todos.css" />
</head>
<body>

  <h1>Список задач</h1>

  <form action="/" method="GET" style="margin-bottom: 25px; display: flex; gap: 10px;">
    <input type="text" name="search" placeholder="Поиск по названию..." style="flex: 1; padding: 10px; border: 1px solid #ccc; border-radius: 5px;">
    <button type="submit" style="padding: 10px 20px; background: #34495e; color: white; border: none; border-radius: 5px; cursor: pointer;">Найти</button>
    <a href="/" style="padding: 10px 15px; background: #95a5a6; color: white; text-decoration: none; border-radius: 5px;">Сбросить</a>
  </form>

  <div class="todo-list">
    <% if (todos && todos.length > 0) { %>
      <% for (let todo of todos) { %>
        <div class="todo-card <%= todo.completed ? 'completed' : '' %>">
          <h3 class="todo-title">
            <a href="/<%= todo._id %>" class="todo-title-link" style="text-decoration: none; color: inherit;">
              <%= todo.title %>
            </a>
          </h3>
          <p class="todo-desc"><%= todo.desc %></p>
          <span class="todo-date">Создано: <%= new Date(todo.createdAt).toLocaleDateString('ru-RU') %></span>
          
          <div class="actions">
            
            <form action="/<%= todo._id %>?_method=PATCH" method="POST" class="form-inline">
              <% if (!todo.completed) { %>
                <input type="hidden" name="completed" value="true">
                <button type="submit" class="btn btn-done">Сделано</button>
              <% } else { %>
                <input type="hidden" name="completed" value="false">
                <button type="submit" class="btn btn-return">Вернуть</button>
              <% } %>
            </form>

            <form action="/<%= todo._id %>?_method=DELETE" method="POST" class="form-inline ml-auto" onsubmit="return confirm('Удалить эту задачу?')">
              <button type="submit" class="btn btn-delete">Удалить</button>
            </form>

          </div>
        </div>
      <% } %>
    <% } else { %>
      <p>Задач не найдено.</p>
    <% } %>
  </div>

</body>
</html>